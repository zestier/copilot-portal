# Zestier's AI Portal — example env.
# Copy to .env and fill in. Required vars marked with (required).

# --- Server ---
HOST=127.0.0.1
PORT=3000
DATA_DIR=./data
LOG_LEVEL=info

# --- Auth ---
# AUTH_MODE: github | shared-secret | none
AUTH_MODE=none

# Required if AUTH_MODE != none. Generate with: openssl rand -base64 48
SESSION_SECRET=

# Required. AES-256-GCM key for at-rest token encryption. 32 raw bytes, base64.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Set to 1 ONLY when AUTH_MODE=none AND HOST=127.0.0.1. The server refuses
# to start with AUTH_MODE=none otherwise.
I_KNOW_THIS_IS_LOCAL=

# --- AUTH_MODE=github ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Comma-separated list of GitHub logins allowed to sign in.
ALLOWED_GITHUB_LOGINS=

# --- AUTH_MODE=shared-secret ---
SHARED_SECRET=

# --- Copilot ---
# Optional override; if empty, the SDK picks up `copilot auth login` creds
# from ~/.copilot/accounts.json on the host.
COPILOT_GITHUB_TOKEN=

# Default backend/model for new conversations.
# DEFAULT_BACKEND_PROVIDER: copilot | openai-compatible
DEFAULT_BACKEND_PROVIDER=copilot
DEFAULT_MODEL=claude-sonnet-4.5

# --- OpenAI-compatible backends ---
# Generic OpenAI-compatible API (for example a hosted or local /v1 endpoint).
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Set to 1 to swap the real Copilot SDK client for an in-process stub that
# echoes prompts back. Used by `pnpm test:e2e` so end-to-end tests don't
# require real Copilot credentials. Do NOT set this in production.
COPILOT_STUB=

# --- Limits ---
IDLE_TIMEOUT_MIN=15
MAX_CONCURRENT_SESSIONS=4
