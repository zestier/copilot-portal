{
	"name": "copilot-portal",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Self-hosted web portal for the GitHub Copilot agent SDK.",
	"scripts": {
		"dev": "vite dev",
		"dev:isolated": "node scripts/dev-isolated.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"serve": "node scripts/serve.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "pnpm run build && playwright test",
		"test:e2e:ui": "pnpm run build && playwright test --ui",
		"verify": "pnpm run lint && pnpm run check && pnpm test -- --run && pnpm run test:e2e",
		"release:bump-actions": "node scripts/bump-actions.mjs",
		"prepare": "node scripts/install-git-hooks.mjs"
	},
	"dependencies": {
		"@github/copilot-sdk": "^0.3.0",
		"better-sqlite3": "^11.3.0",
		"diff": "^7.0.0",
		"dompurify": "^3.1.7",
		"marked": "^14.1.3",
		"ulid": "^2.3.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.48.0",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.7.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/better-sqlite3": "^7.6.11",
		"@types/diff": "^6.0.0",
		"@types/node": "^22.7.0",
		"@vitest/coverage-v8": "2.1.9",
		"eslint": "^9.12.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.0",
		"globals": "^17.6.0",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.7",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.5",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.8.0",
		"vite": "^5.4.8",
		"vitest": "^2.1.2"
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=11"
	},
	"packageManager": "pnpm@11.1.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	}
}
