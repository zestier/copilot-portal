{
	"name": "copilot-portal",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Self-hosted web portal for the GitHub Copilot agent SDK.",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@github/copilot-sdk": "^0.3.0",
		"better-sqlite3": "^11.3.0",
		"diff": "^7.0.0",
		"dompurify": "^3.1.7",
		"jsdom": "^25.0.1",
		"marked": "^14.1.3",
		"shiki": "^1.22.0",
		"ulid": "^2.3.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.48.0",
		"@sveltejs/adapter-node": "^5.2.0",
		"@sveltejs/kit": "^2.7.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/better-sqlite3": "^7.6.11",
		"@types/diff": "^6.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.7.0",
		"eslint": "^9.12.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.45.0",
		"globals": "^17.6.0",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.7",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.5",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.8.0",
		"vite": "^5.4.8",
		"vitest": "^2.1.2"
	},
	"engines": {
		"node": ">=20",
		"pnpm": ">=9"
	},
	"packageManager": "pnpm@11.1.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild"
		]
	}
}
